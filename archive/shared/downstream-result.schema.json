{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DownstreamResult",
  "type": "object",
  "required": [
    "status",
    "result_type",
    "artifacts",
    "summary",
    "open_questions",
    "assumptions_used",
    "approval_pending",
    "next_recommended_action"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "awaiting_approval",
        "blocked",
        "partial"
      ]
    },
    "result_type": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "title",
          "location"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "location": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_pending": {
      "type": "boolean"
    },
    "next_recommended_action": {
      "type": "string"
    }
  }
}