{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskContract",
  "type": "object",
  "required": [
    "goal",
    "scope",
    "constraints",
    "success_criteria",
    "inputs",
    "assumptions",
    "risk_level",
    "approval_required",
    "requested_output"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "object",
      "required": [
        "provided",
        "missing"
      ],
      "properties": {
        "provided": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "approval_required": {
      "type": "boolean"
    },
    "requested_output": {
      "type": "string"
    },
    "next_actor": {
      "type": "string"
    },
    "task_type": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audience": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high"
      ]
    },
    "stage": {
      "type": "string"
    },
    "completion_definition": {
      "type": "string"
    },
    "fallback_if_blocked": {
      "type": "string"
    }
  }
}