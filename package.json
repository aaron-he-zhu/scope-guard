{
  "name": "scope-guard",
  "version": "0.1.0",
  "description": "Scope Guard — deterministic boundary enforcement with risk-based approval gates for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./checker": "./dist/checker.js",
    "./risk": "./dist/risk.js",
    "./scope": "./dist/scope.js",
    "./audit": "./dist/audit.js",
    "./content": "./dist/content.js",
    "./policy": "./dist/policy.js",
    "./output-filter": "./dist/output-filter.js"
  },
  "bin": {
    "scope-guard": "./dist/cli.js",
    "scope-guard-hook": "./dist/hook.js",
    "scope-guard-init": "./dist/init.js",
    "scope-guard-cli": "./dist/cli.js",
    "scope-guard-post": "./dist/hook-post.js"
  },
  "files": [
    "dist",
    "hooks",
    "skills",
    ".claude-plugin",
    "openclaw.plugin.json",
    "scope-boundary.schema.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "node --test dist/test.js",
    "test:package-smoke": "node ./scripts/package-smoke.mjs",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "scope-guard",
    "ai-safety",
    "ai-agent",
    "guardrail",
    "risk",
    "approval-gate",
    "scope-drift",
    "boundary-enforcement",
    "openclaw",
    "claude-code",
    "agent-safety",
    "pre-tool-hook"
  ],
  "author": "aaron-he-zhu",
  "license": "MIT",
  "homepage": "https://github.com/aaron-he-zhu/scope-guard",
  "repository": {
    "type": "git",
    "url": "https://github.com/aaron-he-zhu/scope-guard.git"
  },
  "bugs": {
    "url": "https://github.com/aaron-he-zhu/scope-guard/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22"
  }
}
