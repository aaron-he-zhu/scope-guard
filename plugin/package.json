{
  "name": "@scope-guard/openclaw-plugin",
  "version": "0.1.0",
  "description": "Scope Guard plugin for OpenClaw — deterministic boundary enforcement with risk-based approval gates",
  "type": "module",
  "main": "./dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openclaw",
    "preflight",
    "scope-guard",
    "safety",
    "guardrail",
    "risk",
    "approval-gate"
  ],
  "author": "aaron-he-zhu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aaron-he-zhu/preflight-scope"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22"
  }
}
