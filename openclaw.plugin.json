{
  "id": "scope-guard",
  "name": "Scope Guard",
  "description": "Scope guard with boundary enforcement, risk-based approval gates, and audit trail. Prevents scope drift before every tool call.",
  "version": "0.1.0",
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "scopePath": {
        "type": "string",
        "description": "Path to scope-boundary.json (default: .claude/scope-boundary.json)"
      },
      "policyPath": {
        "type": "string",
        "description": "Path to scope-guard policy JSON (default: .claude/scope-guard-policy.json)"
      },
      "rulesPath": {
        "type": "string",
        "description": "Deprecated alias for policyPath; path to scope-guard policy JSON"
      },
      "auditLogPath": {
        "type": "string",
        "description": "Path to audit log JSONL (default: .claude/scope-guard-audit.jsonl)"
      }
    }
  },
  "uiHints": {
    "scopePath": { "label": "Scope boundary file", "placeholder": ".claude/scope-boundary.json" },
    "policyPath": { "label": "Policy file", "placeholder": ".claude/scope-guard-policy.json" },
    "rulesPath": { "label": "Policy file (legacy)", "placeholder": ".claude/scope-guard-policy.json" },
    "auditLogPath": { "label": "Audit log file", "placeholder": ".claude/scope-guard-audit.jsonl" }
  }
}
